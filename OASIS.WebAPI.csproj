<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="OASIS.WebAPI.Tests\**\*.cs" />
    <Compile Remove="OASIS.WebAPI.IntegrationTests\**\*.cs" />
    <Compile Remove="OASIS.WebAPI.LiveTests\**\*.cs" />
    <Content Remove="OASIS.WebAPI.Tests\**\*" />
    <Content Remove="OASIS.WebAPI.IntegrationTests\**\*" />
    <Content Remove="OASIS.WebAPI.LiveTests\**\*" />
    <EmbeddedResource Remove="OASIS.WebAPI.Tests\**\*" />
    <EmbeddedResource Remove="OASIS.WebAPI.IntegrationTests\**\*" />
    <EmbeddedResource Remove="OASIS.WebAPI.LiveTests\**\*" />
    <None Remove="OASIS.WebAPI.Tests\**\*" />
    <None Remove="OASIS.WebAPI.IntegrationTests\**\*" />
    <None Remove="OASIS.WebAPI.LiveTests\**\*" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.5.0" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.0" />
    <PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="8.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Algorand2" Version="2.0.0.2024051911" />
    <PackageReference Include="Solana.Rpc" Version="8.7.0" />
    <PackageReference Include="Solana.Wallet" Version="8.7.0" />
    <PackageReference Include="FluentValidation.AspNetCore" Version="11.3.0" />
    <PackageReference Include="AutoMapper.Extensions.Microsoft.DependencyInjection" Version="12.0.1" />
  </ItemGroup>
</Project>
