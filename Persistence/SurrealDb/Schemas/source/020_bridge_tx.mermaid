erDiagram
    %% @surreal.schemafull
    %% @surreal.aggregate "BridgeTransactionResult (Models/Responses/BridgeTransactionResult.cs)"
    %% @surreal.guardrail "G6 SCHEMAFULL, G2 idempotency unique index"
    %% @surreal.note "State machine: Initiated->Locked->AwaitingVAA->VAAReady->Redeeming->Completed; terminal Failed, Refunded, Reversing."
    %% @surreal.note "B2 fix: bridge_tx_wormhole_vaa UNIQUE on (wormhole_emitter_chain_id, wormhole_emitter_address, wormhole_sequence) is the canonical Wormhole VAA dedup key. Mirrors consumed_vaa_ledger.consumed_vaa_emitter_address_sequence so a VAA cannot be replayed via the bridge_tx path either. NULL-collision caveat: all three fields are option<...>; rows in modes != Wormhole legitimately leave them NULL and SurrealDB UNIQUE-on-nullable does NOT collide NULLs, so non-Wormhole rows do not contend on this index."
    %% @surreal.note "B3 review: bridge_tx_idempotency_key UNIQUE on option<string> -- NULL rows do NOT collide. The bridge claim flow MUST supply an idempotency_key (validator enforced in api-safety-hardening §4); rows without a key are legacy/diagnostic only and the adapter never inserts NULL via the claim path."
    %% @surreal.note "B3 review: bridge_tx_lock_route UNIQUE on (source_chain, lock_tx_hash, target_chain) where lock_tx_hash is option<string>. Pre-lock rows legitimately have NULL lock_tx_hash; SurrealDB will not collide NULLs so multiple Initiated rows can coexist. Replay-dedup applies only once lock_tx_hash is set (post-lock state)."
    %% @surreal.note "MEDIUM #M4 fix: wormhole_emitter_address is asserted to be the canonical Wormhole 32-byte hex form -- 64 lowercase hex chars, no 0x prefix. Wormhole spec stores emitter addresses padded to 32 bytes regardless of source chain (EVM 20-byte addresses are left-zero-padded). Storing some rows in raw 20-byte form and others in 32-byte form would silently bypass the bridge_tx_wormhole_vaa UNIQUE dedup key for cross-emitter replay. Application code must canonicalize on insert; this ASSERT is the last line of defence."
    bridge_tx {
        %% @surreal.fieldgroup "Core identity"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string id
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string avatar_id
        %% @surreal.fieldgroup "Route"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string source_chain
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string target_chain
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string source_token_id
        option<string> target_token_id
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string source_address
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string target_address
        %% @surreal.fieldgroup "Amount (string for arbitrary precision)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string amount
        %% @surreal.fieldgroup "State machine"
        %% @surreal.assert "$value INSIDE [\"Initiated\", \"Locked\", \"AwaitingVAA\", \"VAAReady\", \"Redeeming\", \"Completed\", \"Failed\", \"Refunded\", \"Reversing\"]"
        string status
        %% @surreal.fieldgroup "Mode"
        %% @surreal.assert "$value INSIDE [\"Trusted\", \"Wormhole\"]"
        %% @surreal.default "\"Trusted\""
        string mode
        %% @surreal.fieldgroup "Transaction hashes (nullable)"
        option<string> lock_tx_hash
        option<string> mint_tx_hash
        option<string> proof_data
        option<string> error_message
        %% @surreal.fieldgroup "Timestamps"
        datetime created_at
        option<datetime> completed_at
        %% @surreal.fieldgroup "Wormhole-specific (populated when mode == Wormhole)"
        option<int> wormhole_emitter_chain_id
        %% @surreal.assert "$value = NONE OR $value =~ /^[0-9a-f]{64}$/"
        option<string> wormhole_emitter_address
        option<int> wormhole_sequence
        option<string> vaa_bytes
        option<int> vaa_signature_count
        option<string> redemption_tx_hash
        %% @surreal.fieldgroup "Exactly-once / atomic-transition safety (G2)"
        option<string> idempotency_key
        %% @surreal.index unique fields=[idempotency_key] name=bridge_tx_idempotency_key
        %% @surreal.index unique fields=[source_chain,lock_tx_hash,target_chain] name=bridge_tx_lock_route
        %% @surreal.index unique fields=[wormhole_emitter_chain_id,wormhole_emitter_address,wormhole_sequence] name=bridge_tx_wormhole_vaa
        %% @surreal.index fields=[avatar_id] name=bridge_tx_avatar_id
        %% @surreal.index fields=[status] name=bridge_tx_status
    }
