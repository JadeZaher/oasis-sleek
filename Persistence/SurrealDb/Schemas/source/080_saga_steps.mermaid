erDiagram
    %% @surreal.schemafull
    %% @surreal.aggregate "SagaStepRecord (Models/Sagas/SagaStepRecord.cs)"
    %% @surreal.guardrail "G6 SCHEMAFULL, G2 conditional-claim single-winner primitive"
    %% @surreal.note "Durable transactional-outbox / saga-step record. One row == one step of one saga instance. The step processor only ever asks 'what is due?' and claims a row with a conditional UPDATE -- the proven api-safety-hardening single-winner primitive."
    %% @surreal.note "G2 single-winner claim: UPDATE saga_steps:<id> SET status='InProgress', claimed_at=now WHERE status='Pending' AND next_run_at<=now RETURN AFTER. Under N concurrent processors at most one row mutates (AffectedCount==1); the rest see zero affected and back off. The conditional predicate (NOT optimistic-concurrency) is the arbiter, so behaviour is identical on Postgres, SQLite, and SurrealDB."
    %% @surreal.note "Crash-safe re-entry: an InProgress row whose claimed_at is older than the lease/visibility timeout is reclaimed atomically (UPDATE ... SET status='Pending', claimed_at=NONE WHERE status='InProgress' AND claimed_at < lease_cutoff). Handlers key irreversible effects on step_idempotency_key (via IIdempotencyStore) so a resumed step is an idempotent replay, never a double-run."
    %% @surreal.note "Generic by construction: no bridge/domain types appear here. saga_name/step_name are free strings and payload is opaque JSON. The bridge becomes one consumer with zero schema change."
    %% @surreal.note "step_idempotency_key is NON-unique here -- dedup of irreversible effects happens in handlers via IIdempotencyStore, NOT via a unique constraint (the outbox legitimately holds many rows per correlation: forward steps + a compensation step + retries)."
    saga_steps {
        %% @surreal.fieldgroup "Core identity"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string id
        %% @surreal.fieldgroup "Instance correlation key (NON-unique -- many rows per instance: forwards + compensation + retries)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string correlation_key
        %% @surreal.fieldgroup "Saga definition + step name (free strings -- generic outbox)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string saga_name
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string step_name
        %% @surreal.fieldgroup "Per-step idempotency key (handler keys irreversible effect on THIS value via IIdempotencyStore -- stable across retries/reclaims)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string step_idempotency_key
        %% @surreal.fieldgroup "Opaque payload (serialized typed step input)"
        string payload
        %% @surreal.fieldgroup "Lifecycle state (StepStatus enum) -- drives the G2 conditional claim"
        %% @surreal.assert "$value INSIDE [\"Pending\", \"InProgress\", \"Completed\", \"Compensating\", \"DeadLettered\"]"
        %% @surreal.default "\"Pending\""
        string status
        %% @surreal.fieldgroup "Compensation flag (forward steps dead-letter on exhaustion, compensation steps dead-letter immediately)"
        %% @surreal.default "false"
        bool is_compensation
        %% @surreal.fieldgroup "Attempts consumed so far"
        %% @surreal.default "0"
        int attempt_count
        %% @surreal.fieldgroup "Earliest UTC time the step may be claimed (pushed out by backoff on retry)"
        datetime next_run_at
        %% @surreal.fieldgroup "Lease/visibility-timeout tracking (NONE when not claimed)"
        option<datetime> claimed_at
        %% @surreal.fieldgroup "Diagnostics"
        option<string> last_error
        option<string> output
        %% @surreal.fieldgroup "Mirror of status==DeadLettered for cheap querying"
        %% @surreal.default "false"
        bool dead_lettered
        %% @surreal.fieldgroup "Timestamps"
        datetime created_at
        datetime updated_at
        %% @surreal.index fields=[correlation_key] name=saga_steps_correlation_key
        %% @surreal.index fields=[status,next_run_at] name=saga_steps_due_scan
        %% @surreal.index fields=[status,claimed_at] name=saga_steps_lease_scan
        %% @surreal.index fields=[step_idempotency_key] name=saga_steps_idempotency_key
    }
