erDiagram
    %% @surreal.schemafull
    %% @surreal.aggregate "Avatar (Models/Avatar.cs)"
    %% @surreal.guardrail "G6 SCHEMAFULL"
    %% @surreal.note "Wallets navigation list is NOT persisted here — owned by IWalletStore via wallet.avatar_id FK."
    avatar {
        string id
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string username
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string email
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string password_hash
        option<string> title
        option<string> first_name
        option<string> last_name
        datetime created_date
        option<datetime> last_beamed_in_date
        %% @surreal.default "true"
        bool is_active
        %% @surreal.default "false"
        bool is_verified
        %% @surreal.default "0"
        int karma
        %% @surreal.default "1"
        int level
        %% @surreal.index unique fields=[username] name=avatar_username
        %% @surreal.index unique fields=[email] name=avatar_email
    }
