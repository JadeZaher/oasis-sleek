erDiagram
    %% @surreal.schemafull
    %% @surreal.aggregate "QuestNodeTemplate (Models/Quest/QuestNodeTemplate.cs)"
    %% @surreal.guardrail "G6 SCHEMAFULL; read-only catalog of reusable node definitions"
    %% @surreal.note "Reusable node definition shared across QuestTemplates. A QuestTemplate's embedded node slot (template_node) references a QuestNodeTemplate by id and supplies ParamOverrides; QuestInstantiator merges DefaultConfig + ParamOverrides + caller parameters into the runtime Quest's QuestNode.Config."
    %% @surreal.note "node_type is the QuestNodeType enum serialised as its C# name (e.g. \"HolonCreate\", \"WalletGet\"). Asserted INSIDE the full enum value set so a schema-drift typo is rejected at INSERT time rather than at the dispatch layer."
    quest_node_template {
        %% @surreal.fieldgroup "Core identity (record id is the Guid('N') of QuestNodeTemplate.Id)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string id
        %% @surreal.fieldgroup "Caller-supplied label"
        string name
        %% @surreal.fieldgroup "QuestNodeType enum name (e.g. HolonCreate, NftMint)"
        %% @surreal.assert "$value INSIDE [\"HolonCreate\", \"HolonUpdate\", \"HolonDelete\", \"HolonGet\", \"HolonQuery\", \"HolonInteract\", \"HolonGetChildren\", \"HolonGetPeers\", \"HolonGetAncestors\", \"HolonGetDescendants\", \"HolonPropagate\", \"HolonCompose\", \"HolonClone\", \"HolonMoveSubtree\", \"NftMint\", \"NftTransfer\", \"NftBurn\", \"NftGet\", \"NftQuery\", \"NftGetMetadata\", \"WalletCreate\", \"WalletUpdate\", \"WalletDelete\", \"WalletGet\", \"WalletQuery\", \"WalletSetDefault\", \"WalletGetPortfolio\", \"StarGenerate\", \"StarDeploy\", \"Search\", \"AvatarNFTGetComposite\", \"BlockchainExecute\", \"Condition\", \"ComposeOutputs\"]"
        string node_type
        %% @surreal.fieldgroup "Optional description"
        option<string> description
        %% @surreal.fieldgroup "JSON default config blob (string-encoded)"
        string default_config
        %% @surreal.fieldgroup "JSON-Schema for config validation"
        string config_schema
        %% @surreal.fieldgroup "JSON-Schema for upstream-input contract"
        string input_schema
        %% @surreal.fieldgroup "JSON-Schema for produced-output contract"
        string output_schema
        %% @surreal.fieldgroup "Semantic version (free string)"
        string version
        %% @surreal.fieldgroup "Owner avatar (Guid('N') hex)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string author_avatar_id
        %% @surreal.fieldgroup "Marketplace visibility flag"
        %% @surreal.default "false"
        bool is_public
        %% @surreal.fieldgroup "Free-form tags (array<string>)"
        array<string> tags
        %% @surreal.index fields=[author_avatar_id] name=quest_node_template_by_author
        %% @surreal.index fields=[node_type] name=quest_node_template_by_type
    }
