<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-target so consumers on .NET Framework / netstandard tooling
         (analyzers, build tasks, CLI utilities) can reference the same
         package as net8.0 production consumers. -->
    <TargetFrameworks>netstandard2.0;net8.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- 1591 = missing XML doc comments; tolerated while internal. -->
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <!-- Package metadata. IsPackable=true so `dotnet pack` produces a .nupkg
       for internal-feed distribution; IsPublishable=false guards against
       accidental `dotnet nuget push` until the publish decision is made. -->
  <PropertyGroup>
    <PackageId>Oasis.SurrealDb.Client</PackageId>
    <Version>0.1.0</Version>
    <Authors>OASIS</Authors>
    <Company>OASIS</Company>
    <Description>Homebake SurrealDB client for OASIS: HTTP transport, parameterized query builder, transactions, multi-statement response model, JSON converters. Internal-only — public NuGet publish deferred.</Description>
    <RepositoryUrl>https://github.com/OASIS/oasis-sleek</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/OASIS/oasis-sleek</PackageProjectUrl>
    <PackageLicenseExpression>UNLICENSED</PackageLicenseExpression>
    <PackageTags>surrealdb;oasis;database</PackageTags>
    <IsPackable>true</IsPackable>
    <IsPublishable>false</IsPublishable>
  </PropertyGroup>

  <ItemGroup>
    <!-- System.Text.Json on netstandard2.0 is not in-box; net8.0 has it built-in. -->
    <PackageReference Include="System.Text.Json" Version="8.0.5" Condition="'$(TargetFramework)' == 'netstandard2.0'" />
    <!-- IAsyncDisposable for netstandard2.0 (built-in on net8.0). -->
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" Version="8.0.0" Condition="'$(TargetFramework)' == 'netstandard2.0'" />
  </ItemGroup>

</Project>
