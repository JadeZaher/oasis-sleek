<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-target so the Schema package can be referenced from both the
         netstandard2.0 analyzer and net8.0 production code. The CLI tool
         (PackAsTool) packages the net8.0 build only; netstandard2.0 stays a
         library-only build with the CLI Program.cs excluded. -->
    <TargetFrameworks>netstandard2.0;net8.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <!-- CLI tool packaging: only meaningful on net8.0 (the executable target). -->
  <PropertyGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <OutputType>Exe</OutputType>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>oasis-surreal</ToolCommandName>
    <RootNamespace>Oasis.SurrealDb.Schema</RootNamespace>
  </PropertyGroup>

  <!-- Exclude the CLI entry point + HTTP adapter from the netstandard2.0 build:
       Task<int> Main and HttpClient APIs are not first-class on netstandard2.0,
       and the library consumers of this package never need them. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <Compile Remove="Program.cs" />
    <Compile Remove="Cli\HttpConnectionAdapter.cs" />
  </ItemGroup>

  <!-- System.Text.Json is in-box on net8.0; explicit on netstandard2.0. Versions
       match Oasis.SurrealDb.Client so the solution restores one set of assemblies. -->
  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="8.0.5" Condition="'$(TargetFramework)' == 'netstandard2.0'" />
  </ItemGroup>

  <PropertyGroup>
    <PackageId>Oasis.SurrealDb.Schema</PackageId>
    <Version>0.1.0</Version>
    <Authors>OASIS</Authors>
    <Company>OASIS</Company>
    <Description>Mermaid-ER schema source-of-truth, .surql generator, and migration runner for OASIS SurrealDB. Internal-only — public NuGet publish deferred.</Description>
    <RepositoryUrl>https://github.com/OASIS/oasis-sleek</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/OASIS/oasis-sleek</PackageProjectUrl>
    <PackageLicenseExpression>UNLICENSED</PackageLicenseExpression>
    <PackageTags>surrealdb;oasis;schema;migration;mermaid</PackageTags>
    <IsPackable>true</IsPackable>
    <IsPublishable>false</IsPublishable>
  </PropertyGroup>

</Project>
