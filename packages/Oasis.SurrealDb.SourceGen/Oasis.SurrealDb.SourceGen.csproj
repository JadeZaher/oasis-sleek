<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Roslyn source generators MUST target netstandard2.0; the compiler
         host may be any runtime and the generator assembly must load in
         process alongside Microsoft.CodeAnalysis. -->
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <!-- Suppress the default inclusion of the generator assembly as a
         compile-time library reference. Loaded as an analyzer/generator. -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <DevelopmentDependency>true</DevelopmentDependency>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsRoslynComponent>true</IsRoslynComponent>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;RS1024</NoWarn>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Oasis.SurrealDb.SourceGen</PackageId>
    <Version>0.1.0</Version>
    <Authors>OASIS</Authors>
    <Company>OASIS</Company>
    <Description>Roslyn IIncrementalGenerator that derives strongly-typed C# POCOs from Mermaid ER schema sources for the Oasis.SurrealDb.* package suite. Eliminates hand-maintained schema-to-POCO drift. Internal-only.</Description>
    <RepositoryUrl>https://github.com/OASIS/oasis-sleek</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/OASIS/oasis-sleek</PackageProjectUrl>
    <PackageLicenseExpression>UNLICENSED</PackageLicenseExpression>
    <PackageTags>surrealdb;oasis;source-generator;roslyn;mermaid</PackageTags>
    <IsPackable>true</IsPackable>
    <IsPublishable>false</IsPublishable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Roslyn SDK. PrivateAssets=all so it is NOT forwarded to consumers.
         Version pinned to match Oasis.SurrealDb.Analyzer for consistent host
         compatibility across analyzer/generator assemblies. -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <!-- Release-tracking files consumed by RS2008 (Microsoft.CodeAnalysis.Analyzers). -->
  <ItemGroup>
    <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
    <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
  </ItemGroup>

  <ItemGroup>
    <!-- Re-uses the existing Mermaid parser from the Schema package. The
         Schema package multi-targets netstandard2.0;net8.0 so a netstandard2.0
         source generator can consume its netstandard2.0 build at compile
         time. PrivateAssets=all keeps the dependency contained to the
         generator so consumers of the resulting .nupkg do not implicitly
         pick up the Schema package as a transitive runtime dependency. -->
    <ProjectReference Include="..\Oasis.SurrealDb.Schema\Oasis.SurrealDb.Schema.csproj"
                      PrivateAssets="all" />
  </ItemGroup>


  <!-- Companion-package wiring: the generator DLL plus the Schema parser
       (compile-time dependency loaded in the same Roslyn host process) ship
       as analyzer assets under analyzers/dotnet/cs/ inside the .nupkg.
       Roslyn picks them up automatically when consumers PackageReference
       this assembly. IncludeBuildOutput=false (above) keeps the generator
       out of the consumer's compile-time references. -->
  <ItemGroup>
    <None Include="$(OutputPath)\$(AssemblyName).dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="$(OutputPath)\Oasis.SurrealDb.Schema.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
  </ItemGroup>

</Project>
