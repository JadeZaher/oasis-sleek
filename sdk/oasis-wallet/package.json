{
  "name": "@oasis/wallet-sdk",
  "version": "0.1.0",
  "description": "Cross-platform wallet SDK for OASIS — client-side signing, multi-chain support, DEX integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./algorand": {
      "types": "./dist/algorand/index.d.ts",
      "import": "./dist/algorand/index.js",
      "require": "./dist/algorand/index.cjs"
    },
    "./solana": {
      "types": "./dist/solana/index.d.ts",
      "import": "./dist/solana/index.js",
      "require": "./dist/solana/index.cjs"
    },
    "./dex": {
      "types": "./dist/dex/index.d.ts",
      "import": "./dist/dex/index.js",
      "require": "./dist/dex/index.cjs"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js",
      "require": "./dist/api/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@msgpack/msgpack": "3.1.3"
  },
  "peerDependencies": {
    "algosdk": "^3.0.0",
    "@solana/web3.js": "^1.90.0",
    "@solana/spl-token": "^0.4.0",
    "@noble/curves": "^1.4.0",
    "@tinymanorg/tinyman-js-sdk": "^2.0.0",
    "react-native-get-random-values": "^1.11.0"
  },
  "peerDependenciesMeta": {
    "algosdk": { "optional": true },
    "@solana/web3.js": { "optional": true },
    "@solana/spl-token": { "optional": true },
    "@noble/curves": { "optional": true },
    "@tinymanorg/tinyman-js-sdk": { "optional": true },
    "react-native-get-random-values": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
