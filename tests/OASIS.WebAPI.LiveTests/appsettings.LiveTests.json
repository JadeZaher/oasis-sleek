{
  "BaseUrl": "https://localhost:5001",
  "TimeoutSeconds": 30,
  "MaxParallelSuites": 4,
  "DefaultHeaders": {
    "Accept": "application/json"
  },
  "TestDiscovery": {
    "PayloadDirectory": "live-tests",
    "FilePattern": "*.jsonl"
  },
  "Output": {
    "ResultsPath": "../live-test-results.md",
    "IncludeResponseBodies": true,
    "TruncateResponseBodyAt": 2000
  }
}
