# ═══════════════════════════════════════════════════════════════
# AvatarController Malicious / Stress Tests
# Attack payloads: SQLi, XSS, oversized data, type confusion, path traversal
# ═══════════════════════════════════════════════════════════════

# ─── SQL Injection Payloads ───
{"id":"sqli_username","description":"SQL injection in username field","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"' OR '1'='1","email":"sqli1@mal.oasis","password":"Pass123!"},"expectedStatusRange":"2xx"}
{"id":"sqli_email","description":"SQL injection in email field","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"sqliuser","email":"' UNION SELECT * FROM avatars--","password":"Pass123!"},"expectedStatusRange":"2xx"}
{"id":"sqli_password","description":"SQL injection in password field","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"sqli2","email":"sqli2@mal.oasis","password":"' DROP TABLE avatars; --"},"expectedStatusRange":"2xx"}
{"id":"sqli_login_email","description":"SQL injection in login email","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"admin' OR '1'='1","password":"anything"},"expectedStatus":401}
{"id":"sqli_login_password","description":"SQL injection in login password","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"test@mal.oasis","password":"' OR '1'='1"},"expectedStatus":401}
{"id":"sqli_blind_union","description":"Blind UNION-based SQLi","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"test","email":"test' UNION SELECT null,null,null,null,null,null,null,null,null,null--","password":"Pass123!"},"expectedStatusRange":"2xx"}

