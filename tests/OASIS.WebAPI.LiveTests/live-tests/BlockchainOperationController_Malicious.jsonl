{"id":"get_by_avatar_no_auth","description":"Get by avatar without auth","method":"GET","path":"/api/blockchainoperation/avatar/{{bcMalAvatar.id}}","headers":{},"expectedStatus":401}
{"id":"get_op_empty_auth","description":"Empty authorization header","method":"GET","path":"/api/blockchainoperation/00000000-0000-0000-0000-000000000000","headers":{"Authorization":""},"expectedStatus":401}
{"id":"get_op_bearer_only","description":"Bearer keyword only no token","method":"GET","path":"/api/blockchainoperation/00000000-0000-0000-0000-000000000000","headers":{"Authorization":"Bearer "},"expectedStatus":401}
{"id":"get_op_tampered_token","description":"Tampered JWT token","method":"GET","path":"/api/blockchainoperation/avatar/{{bcMalAvatar.id}}","headers":{"Authorization":"Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"},"expectedStatus":401}

# ─── Header Injection ───
{"id":"header_injection_op","description":"Header injection via auth header","method":"GET","path":"/api/blockchainoperation/avatar/{{bcMalAvatar.id}}","headers":{"Authorization":"Bearer {{bcMalAuth.token}}\r\nX-Injected: malicious"},"expectedStatus":401}

# ─── Query Parameter Attacks (OASISRequest) ───
{"id":"get_op_sqli_provider_type","description":"SQLi in providerType query param","method":"GET","path":"/api/blockchainoperation/avatar/{{bcMalAvatar.id}}?providerType=' OR '1'='1","headers":{"Authorization":"Bearer {{bcMalAuth.token}}"},"expectedStatusRange":"2xx"}
{"id":"get_op_xss_provider_type","description":"XSS in providerType query param","method":"GET","path":"/api/blockchainoperation/avatar/{{bcMalAvatar.id}}?providerType=<script>alert(1)</script>","headers":{"Authorization":"Bearer {{bcMalAuth.token}}"},"expectedStatusRange":"2xx"}
{"id":"get_op_very_long_query","description":"Very long query string","method":"GET","path":"/api/blockchainoperation/avatar/{{bcMalAvatar.id}}?","headers":{"Authorization":"Bearer {{bcMalAuth.token}}"},"expectedStatusRange":"2xx"}

