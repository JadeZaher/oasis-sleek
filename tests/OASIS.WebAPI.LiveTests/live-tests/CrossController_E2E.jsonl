# ═══════════════════════════════════════════════════════════════
# Cross-Controller End-to-End Flows
# Full lifecycle tests spanning multiple controllers with proper
# avatar authentication and ownership chains.
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# E2E Flow 1: Full Avatar -> Holon -> Mint -> Exchange Lifecycle
# ═══════════════════════════════════════════════════════════════
{"id":"e2e1_register","description":"E2E1: Register avatar","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"e2euser","email":"e2e@flow.oasis","password":"E2EPass123!","title":"Trader","firstName":"End","lastName":"ToEnd"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"e2eAvatar"}
{"id":"e2e1_login","description":"E2E1: Login","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"e2e@flow.oasis","password":"E2EPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"e2eAuth"}
{"id":"e2e1_add_algo_wallet","description":"E2E1: Add Algorand wallet","method":"POST","path":"/api/avatar/{{e2eAvatar.id}}/wallets","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2eAuth.token}}"},"body":{"chainType":"Algorand","address":"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAY5HFKQ","label":"E2E Trading","isDefault":true},"expectedStatus":200,"extract":{"walletId":"result.id"},"saveAs":"e2eWallet"}
{"id":"e2e1_get_wallets","description":"E2E1: Verify wallet exists","method":"GET","path":"/api/avatar/{{e2eAvatar.id}}/wallets","headers":{"Authorization":"Bearer {{e2eAuth.token}}"},"expectedStatus":200}
{"id":"e2e1_create_source_holon","description":"E2E1: Create source holon for minting","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2eAuth.token}}"},"body":{"name":"E2ESource","description":"Source holon for E2E flow","providerName":"InMemory","chainId":"Algorand","assetType":"ASA","metadata":{"flow":"e2e1"}},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"e2eSourceHolon"}
{"id":"e2e1_create_target_holon","description":"E2E1: Create target holon for exchange","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2eAuth.token}}"},"body":{"name":"E2ETarget","description":"Target holon for E2E flow","providerName":"InMemory","chainId":"Algorand","assetType":"ASA","metadata":{"flow":"e2e1"}},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"e2eTargetHolon"}
{"id":"e2e1_mint_source","description":"E2E1: Mint asset on source holon","method":"POST","path":"/api/holon/{{e2eSourceHolon.id}}/mint","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2eAuth.token}}"},"body":{"walletId":"{{e2eWallet.walletId}}","tokenUri":"https://e2e.oasis/token/1","amount":10000,"assetType":"ASA"},"expectedStatus":200,"extract":{"mintOpId":"result.id"},"saveAs":"e2eMintOp"}
{"id":"e2e1_exchange","description":"E2E1: Exchange source -> target","method":"POST","path":"/api/holon/{{e2eSourceHolon.id}}/exchange","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2eAuth.token}}"},"body":{"walletId":"{{e2eWallet.walletId}}","targetHolonId":"{{e2eTargetHolon.id}}","exchangeRate":"2:1"},"expectedStatus":200,"extract":{"exchangeOpId":"result.id"},"saveAs":"e2eExchangeOp"}
{"id":"e2e1_interact_source","description":"E2E1: Add metadata post-exchange","method":"POST","path":"/api/holon/{{e2eSourceHolon.id}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2eAuth.token}}"},"body":{"setMetadata":{"exchanged":"true","rate":"2:1"}},"expectedStatus":200}
{"id":"e2e1_get_mint_op","description":"E2E1: Verify mint operation exists","method":"GET","path":"/api/blockchainoperation/{{e2eMintOp.mintOpId}}","headers":{"Authorization":"Bearer {{e2eAuth.token}}"},"expectedStatus":200}
{"id":"e2e1_get_exchange_op","description":"E2E1: Verify exchange operation exists","method":"GET","path":"/api/blockchainoperation/{{e2eExchangeOp.exchangeOpId}}","headers":{"Authorization":"Bearer {{e2eAuth.token}}"},"expectedStatus":200}
{"id":"e2e1_get_ops_by_avatar","description":"E2E1: List all ops for avatar","method":"GET","path":"/api/blockchainoperation/avatar/{{e2eAvatar.id}}","headers":{"Authorization":"Bearer {{e2eAuth.token}}"},"expectedStatus":200}
{"id":"e2e1_query_holons","description":"E2E1: Query holons by name","method":"GET","path":"/api/holon?name=E2E","headers":{"Authorization":"Bearer {{e2eAuth.token}}"},"expectedStatus":200}
{"id":"e2e1_update_avatar","description":"E2E1: Update avatar profile post-activity","method":"PUT","path":"/api/avatar/{{e2eAvatar.id}}","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2eAuth.token}}"},"body":{"title":"Master Trader","karma":100},"expectedStatus":200}
{"id":"e2e1_cleanup_holons","description":"E2E1: Delete target holon","method":"DELETE","path":"/api/holon/{{e2eTargetHolon.id}}","headers":{"Authorization":"Bearer {{e2eAuth.token}}"},"expectedStatus":200}
{"id":"e2e1_cleanup_source_holon","description":"E2E1: Delete source holon","method":"DELETE","path":"/api/holon/{{e2eSourceHolon.id}}","headers":{"Authorization":"Bearer {{e2eAuth.token}}"},"expectedStatus":200}
{"id":"e2e1_cleanup_wallet","description":"E2E1: Remove wallet","method":"DELETE","path":"/api/avatar/{{e2eAvatar.id}}/wallets/{{e2eWallet.walletId}}","headers":{"Authorization":"Bearer {{e2eAuth.token}}"},"expectedStatus":200}
{"id":"e2e1_cleanup_avatar","description":"E2E1: Delete avatar","method":"DELETE","path":"/api/avatar/{{e2eAvatar.id}}","headers":{"Authorization":"Bearer {{e2eAuth.token}}"},"expectedStatus":200}

# ═══════════════════════════════════════════════════════════════
# E2E Flow 2: Avatar -> STAR ODK -> Generate -> Deploy with Bound Holons
# ═══════════════════════════════════════════════════════════════
{"id":"e2e2_register","description":"E2E2: Register ODK developer avatar","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"odkdev","email":"odkdev@flow.oasis","password":"E2EPass123!","firstName":"ODK","lastName":"Developer"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"e2e2Avatar"}
{"id":"e2e2_login","description":"E2E2: Login","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"odkdev@flow.oasis","password":"E2EPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"e2e2Auth"}
{"id":"e2e2_create_holon_a","description":"E2E2: Create bound holon A","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e2Auth.token}}"},"body":{"name":"BoundHolonA","description":"First bound holon","providerName":"InMemory","chainId":"Algorand","metadata":{"binding":"true"}},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"e2e2HolonA"}
{"id":"e2e2_create_holon_b","description":"E2E2: Create bound holon B","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e2Auth.token}}"},"body":{"name":"BoundHolonB","description":"Second bound holon","providerName":"InMemory","chainId":"Algorand","metadata":{"binding":"true"}},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"e2e2HolonB"}
{"id":"e2e2_create_odk","description":"E2E2: Create STAR ODK","method":"POST","path":"/api/starodk","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e2Auth.token}}"},"body":{"name":"E2EDapp","description":"End-to-end generated dApp","publicKey":"0xE2EPUBKEY","avatarId":"{{e2e2Avatar.id}}"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"e2e2ODK"}
{"id":"e2e2_generate_odk","description":"E2E2: Generate dApp with bound holons","method":"POST","path":"/api/starodk/{{e2e2ODK.id}}/generate","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e2Auth.token}}"},"body":{"targetChain":"Algorand","boundHolonIds":["{{e2e2HolonA.id}}","{{e2e2HolonB.id}}"],"config":{"theme":"dark","features":["mint","exchange"]}},"expectedStatus":200}
{"id":"e2e2_get_odk_post_gen","description":"E2E2: Verify ODK has generated code","method":"GET","path":"/api/starodk/{{e2e2ODK.id}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_deploy_odk","description":"E2E2: Deploy generated dApp","method":"POST","path":"/api/starodk/{{e2e2ODK.id}}/deploy","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_get_odk_post_deploy","description":"E2E2: Verify ODK has deployment config","method":"GET","path":"/api/starodk/{{e2e2ODK.id}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_get_all_odks","description":"E2E2: List all ODKs","method":"GET","path":"/api/starodk","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_cleanup_odk","description":"E2E2: Delete ODK","method":"DELETE","path":"/api/starodk/{{e2e2ODK.id}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_cleanup_holon_a","description":"E2E2: Delete holon A","method":"DELETE","path":"/api/holon/{{e2e2HolonA.id}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_cleanup_holon_b","description":"E2E2: Delete holon B","method":"DELETE","path":"/api/holon/{{e2e2HolonB.id}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_cleanup_avatar","description":"E2E2: Delete avatar","method":"DELETE","path":"/api/avatar/{{e2e2Avatar.id}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}

# ═══════════════════════════════════════════════════════════════
# E2E Flow 3: Multi-Avatar Isolation Verification
# ═══════════════════════════════════════════════════════════════
{"id":"e2e3_register_alpha","description":"E2E3: Register Alpha avatar","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"alpha","email":"alpha@iso.oasis","password":"IsoPass123!"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"alphaAvatar"}
{"id":"e2e3_login_alpha","description":"E2E3: Login Alpha","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"alpha@iso.oasis","password":"IsoPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"alphaAuth"}
{"id":"e2e3_register_beta","description":"E2E3: Register Beta avatar","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"beta","email":"beta@iso.oasis","password":"IsoPass123!"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"betaAvatar"}
{"id":"e2e3_login_beta","description":"E2E3: Login Beta","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"beta@iso.oasis","password":"IsoPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"betaAuth"}
{"id":"e2e3_alpha_create_holon","description":"E2E3: Alpha creates private holon","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{alphaAuth.token}}"},"body":{"name":"AlphaSecret","description":"Alpha's private holon","providerName":"InMemory","metadata":{"owner":"alpha"}},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"alphaHolon"}
{"id":"e2e3_beta_create_holon","description":"E2E3: Beta creates private holon","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{betaAuth.token}}"},"body":{"name":"BetaSecret","description":"Beta's private holon","providerName":"InMemory","metadata":{"owner":"beta"}},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"betaHolon"}
{"id":"e2e3_alpha_get_own","description":"E2E3: Alpha gets own holon","method":"GET","path":"/api/holon/{{alphaHolon.id}}","headers":{"Authorization":"Bearer {{alphaAuth.token}}"},"expectedStatus":200}
{"id":"e2e3_beta_get_own","description":"E2E3: Beta gets own holon","method":"GET","path":"/api/holon/{{betaHolon.id}}","headers":{"Authorization":"Bearer {{betaAuth.token}}"},"expectedStatus":200}
{"id":"e2e3_alpha_get_beta","description":"E2E3: Alpha tries to get Beta's holon","method":"GET","path":"/api/holon/{{betaHolon.id}}","headers":{"Authorization":"Bearer {{alphaAuth.token}}"},"expectedStatus":200}
{"id":"e2e3_beta_get_alpha","description":"E2E3: Beta tries to get Alpha's holon","method":"GET","path":"/api/holon/{{alphaHolon.id}}","headers":{"Authorization":"Bearer {{betaAuth.token}}"},"expectedStatus":200}
{"id":"e2e3_query_all","description":"E2E3: Query all holons - both should be visible","method":"GET","path":"/api/holon","headers":{"Authorization":"Bearer {{alphaAuth.token}}"},"expectedStatus":200}
{"id":"e2e3_cleanup_alpha_holon","description":"E2E3: Delete Alpha's holon","method":"DELETE","path":"/api/holon/{{alphaHolon.id}}","headers":{"Authorization":"Bearer {{alphaAuth.token}}"},"expectedStatus":200}
{"id":"e2e3_cleanup_beta_holon","description":"E2E3: Delete Beta's holon","method":"DELETE","path":"/api/holon/{{betaHolon.id}}","headers":{"Authorization":"Bearer {{betaAuth.token}}"},"expectedStatus":200}
{"id":"e2e3_cleanup_alpha","description":"E2E3: Delete Alpha avatar","method":"DELETE","path":"/api/avatar/{{alphaAvatar.id}}","headers":{"Authorization":"Bearer {{alphaAuth.token}}"},"expectedStatus":200}
{"id":"e2e3_cleanup_beta","description":"E2E3: Delete Beta avatar","method":"DELETE","path":"/api/avatar/{{betaAvatar.id}}","headers":{"Authorization":"Bearer {{betaAuth.token}}"},"expectedStatus":200}
