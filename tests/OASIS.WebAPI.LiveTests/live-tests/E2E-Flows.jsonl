# ═══════════════════════════════════════════════════════════════
# E2E Cross-Controller Flows & Rapid Sequential Stress Tests
# Holons belong to avatars via JWT claims — all auth flows use
# real register/login/token chains. Suites are self-contained
# for parallel-safe execution.
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# FLOW 1: Full Avatar Lifecycle with Holon Ownership
# Register → Login → Create Holon → Query → Update Holon →
# Interact → Create Sub-Holon → Update Parent → Delete Sub →
# Delete Holon → Delete Avatar
# ═══════════════════════════════════════════════════════════════
{"id":"e2e1_register","description":"[E2E-1] Register avatar","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"e2eavatar","email":"e2e1@test.oasis","password":"TestPass123!","title":"E2E","firstName":"End","lastName":"ToEnd"},"expectedStatus":200,"extract":{"avatarId":"result.id"},"saveAs":"e2e1Avatar"}
{"id":"e2e1_login","description":"[E2E-1] Login","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"e2e1@test.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"e2e1Auth"}
{"id":"e2e1_add_wallet","description":"[E2E-1] Add wallet","method":"POST","path":"/api/avatar/{{e2e1Avatar.avatarId}}/wallets","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e1Auth.token}}"},"body":{"chainType":"Algorand","address":"E2EADDR1234567890123456789012345678","label":"E2EWallet","isDefault":true},"expectedStatus":200,"extract":{"walletId":"result.id"},"saveAs":"e2e1Wallet"}
{"id":"e2e1_create_holon","description":"[E2E-1] Create parent holon","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e1Auth.token}}"},"body":{"name":"E2EParentHolon","description":"Parent in E2E flow","providerName":"InMemory","metadata":{"flow":"e2e1","stage":"created"}},"expectedStatus":200,"extract":{"holonId":"result.id"},"saveAs":"e2e1ParentHolon"}
{"id":"e2e1_get_holon","description":"[E2E-1] Verify holon ownership via GET","method":"GET","path":"/api/holon/{{e2e1ParentHolon.holonId}}","headers":{"Authorization":"Bearer {{e2e1Auth.token}}"},"expectedStatus":200}
{"id":"e2e1_query_holons","description":"[E2E-1] Query holons by name","method":"GET","path":"/api/holon?name=E2EParentHolon","headers":{"Authorization":"Bearer {{e2e1Auth.token}}"},"expectedStatus":200}
{"id":"e2e1_update_holon","description":"[E2E-1] Update holon metadata","method":"PUT","path":"/api/holon/{{e2e1ParentHolon.holonId}}","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e1Auth.token}}"},"body":{"description":"Updated in E2E flow","metadata":{"flow":"e2e1","stage":"updated"}},"expectedStatus":200}
{"id":"e2e1_interact_holon","description":"[E2E-1] Interact adding metadata","method":"POST","path":"/api/holon/{{e2e1ParentHolon.holonId}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e1Auth.token}}"},"body":{"setMetadata":{"interaction":"true","timestamp":"e2e1"}},"expectedStatus":200}
{"id":"e2e1_create_subholon","description":"[E2E-1] Create child holon with parent","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e1Auth.token}}"},"body":{"name":"E2ESubHolon","description":"Child holon","providerName":"InMemory","parentHolonId":"{{e2e1ParentHolon.holonId}}","metadata":{"parentFlow":"e2e1"}},"expectedStatus":200,"extract":{"holonId":"result.id"},"saveAs":"e2e1SubHolon"}
{"id":"e2e1_get_subholon","description":"[E2E-1] Get child holon","method":"GET","path":"/api/holon/{{e2e1SubHolon.holonId}}","headers":{"Authorization":"Bearer {{e2e1Auth.token}}"},"expectedStatus":200}
{"id":"e2e1_delete_subholon","description":"[E2E-1] Delete child holon","method":"DELETE","path":"/api/holon/{{e2e1SubHolon.holonId}}","headers":{"Authorization":"Bearer {{e2e1Auth.token}}"},"expectedStatus":200}
{"id":"e2e1_delete_holon","description":"[E2E-1] Delete parent holon","method":"DELETE","path":"/api/holon/{{e2e1ParentHolon.holonId}}","headers":{"Authorization":"Bearer {{e2e1Auth.token}}"},"expectedStatus":200}
{"id":"e2e1_remove_wallet","description":"[E2E-1] Remove wallet","method":"DELETE","path":"/api/avatar/{{e2e1Avatar.avatarId}}/wallets/{{e2e1Wallet.walletId}}","headers":{"Authorization":"Bearer {{e2e1Auth.token}}"},"expectedStatus":200}
{"id":"e2e1_delete_avatar","description":"[E2E-1] Delete avatar","method":"DELETE","path":"/api/avatar/{{e2e1Avatar.avatarId}}","headers":{"Authorization":"Bearer {{e2e1Auth.token}}"},"expectedStatus":200}


# ═══════════════════════════════════════════════════════════════
# FLOW 2: STAR ODK + Holon Binding Lifecycle
# Register → Login → Create Holon → Create ODK → Generate →
# Deploy → Delete ODK → Delete Holon → Delete Avatar
# ═══════════════════════════════════════════════════════════════
{"id":"e2e2_register","description":"[E2E-2] Register avatar","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"e2e2avatar","email":"e2e2@test.oasis","password":"TestPass123!","firstName":"Star","lastName":"Flow"},"expectedStatus":200,"extract":{"avatarId":"result.id"},"saveAs":"e2e2Avatar"}
{"id":"e2e2_login","description":"[E2E-2] Login","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"e2e2@test.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"e2e2Auth"}
{"id":"e2e2_create_holon","description":"[E2E-2] Create holon to bind to ODK","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e2Auth.token}}"},"body":{"name":"E2E2BoundHolon","description":"Bound to ODK","providerName":"InMemory","metadata":{"bound":"true"}},"expectedStatus":200,"extract":{"holonId":"result.id"},"saveAs":"e2e2Holon"}
{"id":"e2e2_create_odk","description":"[E2E-2] Create STAR ODK linked to avatar","method":"POST","path":"/api/starodk","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e2Auth.token}}"},"body":{"name":"E2E2ODK","description":"E2E bound ODK","publicKey":"0xE2EPUBLICKEY","avatarId":"{{e2e2Avatar.avatarId}}"},"expectedStatus":200,"extract":{"odkId":"result.id"},"saveAs":"e2e2Odk"}
{"id":"e2e2_get_odk","description":"[E2E-2] Get created ODK","method":"GET","path":"/api/starodk/{{e2e2Odk.odkId}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_get_all_odks","description":"[E2E-2] List all ODKs","method":"GET","path":"/api/starodk","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_generate_odk","description":"[E2E-2] Generate dApp with bound holon","method":"POST","path":"/api/starodk/{{e2e2Odk.odkId}}/generate","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e2Auth.token}}"},"body":{"targetChain":"Algorand","boundHolonIds":["{{e2e2Holon.holonId}}"],"config":{"theme":"light","enableBridge":true}},"expectedStatus":200}
{"id":"e2e2_delete_odk","description":"[E2E-2] Delete ODK","method":"DELETE","path":"/api/starodk/{{e2e2Odk.odkId}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_delete_holon","description":"[E2E-2] Delete bound holon","method":"DELETE","path":"/api/holon/{{e2e2Holon.holonId}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}
{"id":"e2e2_delete_avatar","description":"[E2E-2] Delete avatar","method":"DELETE","path":"/api/avatar/{{e2e2Avatar.avatarId}}","headers":{"Authorization":"Bearer {{e2e2Auth.token}}"},"expectedStatus":200}


# ═══════════════════════════════════════════════════════════════
# FLOW 3: Multi-Avatar Holon Isolation
# Verify that avatars cannot access each other's holons.
# ═══════════════════════════════════════════════════════════════
{"id":"e2e3_register_a","description":"[E2E-3] Register avatar A","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"e2e3a","email":"e2e3a@test.oasis","password":"TestPass123!","firstName":"Alice"},"expectedStatus":200,"extract":{"avatarId":"result.id"},"saveAs":"e2e3AvatarA"}
{"id":"e2e3_login_a","description":"[E2E-3] Login avatar A","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"e2e3a@test.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"e2e3AuthA"}
{"id":"e2e3_create_holon_a","description":"[E2E-3] Avatar A creates holon","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e3AuthA.token}}"},"body":{"name":"AliceHolon","description":"Owned by Alice","providerName":"InMemory"},"expectedStatus":200,"extract":{"holonId":"result.id"},"saveAs":"e2e3HolonA"}
{"id":"e2e3_register_b","description":"[E2E-3] Register avatar B","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"e2e3b","email":"e2e3b@test.oasis","password":"TestPass123!","firstName":"Bob"},"expectedStatus":200,"extract":{"avatarId":"result.id"},"saveAs":"e2e3AvatarB"}
{"id":"e2e3_login_b","description":"[E2E-3] Login avatar B","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"e2e3b@test.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"e2e3AuthB"}
{"id":"e2e3_b_get_a_holon","description":"[E2E-3] Avatar B tries to get A's holon","method":"GET","path":"/api/holon/{{e2e3HolonA.holonId}}","headers":{"Authorization":"Bearer {{e2e3AuthB.token}}"},"expectedStatus":404}
{"id":"e2e3_b_update_a_holon","description":"[E2E-3] Avatar B tries to update A's holon","method":"PUT","path":"/api/holon/{{e2e3HolonA.holonId}}","headers":{"Content-Type":"application/json","Authorization":"Bearer {{e2e3AuthB.token}}"},"body":{"description":"Hacked by Bob"},"expectedStatus":404}
{"id":"e2e3_b_delete_a_holon","description":"[E2E-3] Avatar B tries to delete A's holon","method":"DELETE","path":"/api/holon/{{e2e3HolonA.holonId}}","headers":{"Authorization":"Bearer {{e2e3AuthB.token}}"},"expectedStatus":404}
{"id":"e2e3_cleanup_holon_a","description":"[E2E-3] Avatar A deletes her holon","method":"DELETE","path":"/api/holon/{{e2e3HolonA.holonId}}","headers":{"Authorization":"Bearer {{e2e3AuthA.token}}"},"expectedStatus":200}
{"id":"e2e3_cleanup_avatar_a","description":"[E2E-3] Delete avatar A","method":"DELETE","path":"/api/avatar/{{e2e3AvatarA.avatarId}}","headers":{"Authorization":"Bearer {{e2e3AuthA.token}}"},"expectedStatus":200}
{"id":"e2e3_cleanup_avatar_b","description":"[E2E-3] Delete avatar B","method":"DELETE","path":"/api/avatar/{{e2e3AvatarB.avatarId}}","headers":{"Authorization":"Bearer {{e2e3AuthB.token}}"},"expectedStatus":200}


