{"id":"interact_circular_parent","description":"Set holon as its own parent","method":"POST","path":"/api/holon/{{targetHolon.id}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"newParentHolonId":"{{targetHolon.id}}"},"expectedStatus":200}
