# ═══════════════════════════════════════════════════════════════
# HolonController Comprehensive QA
# Holons belong to avatars via JWT claims. Tests cover:
# - CRUD lifecycle with proper auth
# - Peer relationships
# - Interaction (metadata, parent, peers)
# - Avatar isolation (one avatar cannot access another's holons)
# - Query variations
# ═══════════════════════════════════════════════════════════════

# ─── Seed Avatar A ───
{"id":"seed_avatar_a","description":"Register avatar A for holon ownership tests","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"holonowner_a","email":"holona@qa.oasis","password":"TestPass123!","firstName":"Owner","lastName":"Alpha"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"avatarA"}
{"id":"login_avatar_a","description":"Login avatar A","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"holona@qa.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"authA"}

# ─── Seed Avatar B (for isolation tests) ───
{"id":"seed_avatar_b","description":"Register avatar B for isolation tests","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"holonowner_b","email":"holonb@qa.oasis","password":"TestPass123!","firstName":"Owner","lastName":"Beta"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"avatarB"}
{"id":"login_avatar_b","description":"Login avatar B","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"holonb@qa.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"authB"}

# ─── Create Holons for Avatar A ───
{"id":"create_root_holon","description":"Create root holon for avatar A","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"name":"RootHolon","description":"Root holon created by QA suite","providerName":"InMemory","metadata":{"env":"qa","suite":"holon_qa"}},"expectedStatus":200,"extract":{"id":"result.id","avatarId":"result.avatarId"},"saveAs":"rootHolon"}
{"id":"create_child_holon","description":"Create child holon with parent reference","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"name":"ChildHolon","description":"Child of root","providerName":"InMemory","parentHolonId":"{{rootHolon.id}}","metadata":{"parent":"root"}},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"childHolon"}
{"id":"create_peer_holon","description":"Create holon that will be a peer","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"name":"PeerHolon","description":"Peer holon for relationship tests","providerName":"InMemory","metadata":{"role":"peer"}},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"peerHolon"}
{"id":"create_chain_holon","description":"Create holon on Algorand chain","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"name":"ChainHolon","description":"Holon with chain association","providerName":"InMemory","chainId":"Algorand","assetType":"ASA","metadata":{"network":"devnet"}},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"chainHolon"}

# ─── Verify Ownership ───
{"id":"get_root_holon","description":"Get root holon by ID","method":"GET","path":"/api/holon/{{rootHolon.id}}","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}
{"id":"verify_avatar_id_set","description":"Verify holon has correct avatarId from JWT","method":"GET","path":"/api/holon/{{rootHolon.id}}","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}

# ─── Query Tests ───
{"id":"query_by_name","description":"Query holons by name filter","method":"GET","path":"/api/holon?name=RootHolon","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}
{"id":"query_no_filter","description":"Query all holons (no filter)","method":"GET","path":"/api/holon","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}
{"id":"query_nonexistent","description":"Query with name that doesn't match","method":"GET","path":"/api/holon?name=NonExistentHolonXYZ","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}

# ─── Update Tests ───
{"id":"update_name","description":"Update holon name only","method":"PUT","path":"/api/holon/{{rootHolon.id}}","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"name":"RootHolonUpdated"},"expectedStatus":200}
{"id":"update_metadata","description":"Update holon metadata","method":"PUT","path":"/api/holon/{{rootHolon.id}}","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"metadata":{"updated":"true","version":"2"}},"expectedStatus":200}
{"id":"update_chain","description":"Update chain and asset type","method":"PUT","path":"/api/holon/{{chainHolon.id}}","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"chainId":"Solana","assetType":"SPL","tokenId":"sol_token_123"},"expectedStatus":200}
{"id":"update_nonexistent","description":"Update non-existent holon","method":"PUT","path":"/api/holon/00000000-0000-0000-0000-000000000000","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"name":"Ghost"},"expectedStatus":404}

# ─── Interaction Tests ───
{"id":"interact_add_peers","description":"Add peer holons via interact","method":"POST","path":"/api/holon/{{rootHolon.id}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"addPeerHolonIds":["{{peerHolon.id}}"],"setMetadata":{"peerCount":"1"}},"expectedStatus":200}
{"id":"interact_change_parent","description":"Change parent holon via interact","method":"POST","path":"/api/holon/{{childHolon.id}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"newParentHolonId":"{{peerHolon.id}}"},"expectedStatus":200}
{"id":"interact_remove_metadata","description":"Remove metadata keys via interact","method":"POST","path":"/api/holon/{{rootHolon.id}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"removeMetadataKeys":["peerCount"],"setMetadata":{"cleaned":"true"}},"expectedStatus":200}
{"id":"interact_remove_peers","description":"Remove peer holons via interact","method":"POST","path":"/api/holon/{{rootHolon.id}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authA.token}}"},"body":{"removePeerHolonIds":["{{peerHolon.id}}"]},"expectedStatus":200}

# ─── Isolation Tests ───
{"id":"isolation_avatar_b_get_a_holon","description":"Avatar B tries to get avatar A's holon","method":"GET","path":"/api/holon/{{rootHolon.id}}","headers":{"Authorization":"Bearer {{authB.token}}"},"expectedStatus":200}
{"id":"isolation_avatar_b_update_a_holon","description":"Avatar B tries to update avatar A's holon","method":"PUT","path":"/api/holon/{{rootHolon.id}}","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authB.token}}"},"body":{"name":"Hacked"},"expectedStatus":200}
{"id":"isolation_avatar_b_delete_a_holon","description":"Avatar B tries to delete avatar A's holon","method":"DELETE","path":"/api/holon/{{rootHolon.id}}","headers":{"Authorization":"Bearer {{authB.token}}"},"expectedStatus":200}
{"id":"isolation_unauth_create","description":"Create holon without auth","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json"},"body":{"name":"UnauthHolon","description":"Should fail","providerName":"InMemory"},"expectedStatus":401}

# ─── Create Holon for Avatar B ───
{"id":"create_b_holon","description":"Create holon for avatar B","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{authB.token}}"},"body":{"name":"BetaHolon","description":"Belongs to avatar B","providerName":"InMemory"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"bHolon"}

# ─── Cleanup ───
{"id":"delete_child_holon","description":"Delete child holon","method":"DELETE","path":"/api/holon/{{childHolon.id}}","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}
{"id":"delete_peer_holon","description":"Delete peer holon","method":"DELETE","path":"/api/holon/{{peerHolon.id}}","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}
{"id":"delete_chain_holon","description":"Delete chain holon","method":"DELETE","path":"/api/holon/{{chainHolon.id}}","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}
{"id":"delete_root_holon","description":"Delete root holon","method":"DELETE","path":"/api/holon/{{rootHolon.id}}","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}
{"id":"delete_b_holon","description":"Delete avatar B's holon","method":"DELETE","path":"/api/holon/{{bHolon.id}}","headers":{"Authorization":"Bearer {{authB.token}}"},"expectedStatus":200}
{"id":"verify_deleted_holon","description":"Verify deleted holon returns 404","method":"GET","path":"/api/holon/{{rootHolon.id}}","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":404}
{"id":"delete_nonexistent_holon","description":"Delete non-existent holon","method":"DELETE","path":"/api/holon/00000000-0000-0000-0000-000000000000","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":404}
{"id":"cleanup_avatar_a","description":"Delete avatar A","method":"DELETE","path":"/api/avatar/{{avatarA.id}}","headers":{"Authorization":"Bearer {{authA.token}}"},"expectedStatus":200}
{"id":"cleanup_avatar_b","description":"Delete avatar B","method":"DELETE","path":"/api/avatar/{{avatarB.id}}","headers":{"Authorization":"Bearer {{authB.token}}"},"expectedStatus":200}
