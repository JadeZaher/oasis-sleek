{"id":"mal_float_amount","description":"Mint with float amount","method":"POST","path":"/api/holon/88888888-8888-8888-8888-888888888888/mint","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malHAuth.token}}"},"body":{"walletId":"00000000-0000-0000-0000-000000000000","tokenUri":"ipfs://float","amount":1.5,"assetType":"NFT"},"expectedStatus":404}
{"id":"mal_max_int","description":"Mint with max int amount","method":"POST","path":"/api/holon/88888888-8888-8888-8888-888888888888/mint","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malHAuth.token}}"},"body":{"walletId":"00000000-0000-0000-0000-000000000000","tokenUri":"ipfs://maxint","amount":2147483647,"assetType":"NFT"},"expectedStatus":404}

# Unicode normalization / homograph attacks
{"id":"mal_homograph_email","description":"Homograph email using unicode","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"homograph","email":"аdmin@test.oasis","password":"TestPass123!"},"expectedStatus":400}
{"id":"mal_rtl_email","description":"RTL override in email","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"rtl","email":"test@oasis\u202Ehsif\u202C.oasis","password":"TestPass123!"},"expectedStatus":400}

# Zero-width joiner / invisible chars
{"id":"mal_zwj_username","description":"Username with zero-width joiners","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"user\u200D\u200C\u200Badmin","email":"zwj@test.oasis","password":"TestPass123!"},"expectedStatus":400}

# Path traversal in string fields
{"id":"mal_path_wallet","description":"Path traversal in wallet address","method":"POST","path":"/api/avatar/{{malAvatar.avatarId}}/wallets","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"chainType":"Algorand","address":"../../../etc/passwd","label":"PathWallet"},"expectedStatus":400}
{"id":"mal_path_chaintype","description":"Path traversal in chainType","method":"POST","path":"/api/avatar/{{malAvatar.avatarId}}/wallets","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malAuth.token}}"},"body":{"chainType":"../../etc/shadow","address":"ADDR123","label":"PathChain"},"expectedStatus":400}

# Template injection attempts
{"id":"mal_template_username","description":"Template injection in username","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"{{7*7}}","email":"ssti1@test.oasis","password":"TestPass123!"},"expectedStatus":400}
{"id":"mal_template_email","description":"Template injection in email","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"sstiuser","email":"${7*7}@test.oasis","password":"TestPass123!"},"expectedStatus":400}
{"id":"mal_template_jinja","description":"Jinja-like template injection","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"{% import os %}","email":"ssti2@test.oasis","password":"TestPass123!"},"expectedStatus":400}

# XML / XXE-like payloads
{"id":"mal_xml_username","description":"XML entity in username","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"<!ENTITY xxe SYSTEM \"file:///etc/passwd\">","email":"xxe1@test.oasis","password":"TestPass123!"},"expectedStatus":400}
{"id":"mal_xml_json_body","description":"Send XML instead of JSON","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":"<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"file:///etc/passwd\">]><foo>&xxe;</foo>","expectedStatus":400}

# Array where object expected
{"id":"mal_array_body_register","description":"Send array instead of object for register","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":["username","email","password"],"expectedStatus":400}
{"id":"mal_array_body_login","description":"Send array instead of object for login","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":["email","password"],"expectedStatus":400}
{"id":"mal_string_body_holon","description":"Send string instead of object for holon create","method":"POST","path":"/api/holon","headers":{"Content-Type":"application/json","Authorization":"Bearer {{malHAuth.token}}"},"body":"just-a-string","expectedStatus":400}

# Boolean coercion attacks
{"id":"mal_bool_username","description":"Boolean as username","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":true,"email":"bool@test.oasis","password":"TestPass123!"},"expectedStatus":400}
{"id":"mal_bool_password","description":"Boolean as password","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"booluser","email":"bool2@test.oasis","password":false},"expectedStatus":400}

