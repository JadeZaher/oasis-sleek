# ═══════════════════════════════════════════════════════════════
# STARODKController Comprehensive QA
# Covers: create, get, getall, generate, deploy, delete, auth
# ═══════════════════════════════════════════════════════════════

# ─── Seed Avatar ───
{"id":"seed_avatar","description":"Register avatar for STAR ODK tests","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"starqa","email":"star@qa.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"starAvatar"}
{"id":"login_avatar","description":"Login as STAR test avatar","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"star@qa.oasis","password":"TestPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"starAuth"}

# ─── Create ODKs ───
{"id":"create_odk_basic","description":"Create basic STAR ODK","method":"POST","path":"/api/starodk","headers":{"Content-Type":"application/json","Authorization":"Bearer {{starAuth.token}}"},"body":{"name":"BasicODK","description":"Basic ODK for QA","publicKey":"0xTESTPUBKEY123","avatarId":"{{starAvatar.id}}"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"odkBasic"}
{"id":"create_odk_advanced","description":"Create advanced STAR ODK with all fields","method":"POST","path":"/api/starodk","headers":{"Content-Type":"application/json","Authorization":"Bearer {{starAuth.token}}"},"body":{"name":"AdvancedODK","description":"Advanced ODK with binding","publicKey":"0xADVANCEDPUBKEY456","avatarId":"{{starAvatar.id}}"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"odkAdvanced"}
{"id":"create_odk_unicode","description":"Create ODK with Unicode name","method":"POST","path":"/api/starodk","headers":{"Content-Type":"application/json","Authorization":"Bearer {{starAuth.token}}"},"body":{"name":"ODK_测试","description":"Unicode test ODK","publicKey":"0xUNICODE789","avatarId":"{{starAvatar.id}}"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"odkUnicode"}

# ─── Get Tests ───
{"id":"get_odk_by_id","description":"Get ODK by ID","method":"GET","path":"/api/starodk/{{odkBasic.id}}","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":200}
{"id":"get_nonexistent_odk","description":"Get non-existent ODK","method":"GET","path":"/api/starodk/00000000-0000-0000-0000-000000000000","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":404}
{"id":"get_all_odks","description":"List all ODKs","method":"GET","path":"/api/starodk","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":200}

# ─── Generate Tests ───
{"id":"generate_odk_algorand","description":"Generate dApp for Algorand","method":"POST","path":"/api/starodk/{{odkBasic.id}}/generate","headers":{"Content-Type":"application/json","Authorization":"Bearer {{starAuth.token}}"},"body":{"targetChain":"Algorand","boundHolonIds":[],"config":{"theme":"dark","debug":true}},"expectedStatus":200}
{"id":"generate_odk_solana","description":"Generate dApp for Solana","method":"POST","path":"/api/starodk/{{odkAdvanced.id}}/generate","headers":{"Content-Type":"application/json","Authorization":"Bearer {{starAuth.token}}"},"body":{"targetChain":"Solana","boundHolonIds":[],"config":{"theme":"light","rpc":"devnet"}},"expectedStatus":200}

# ─── Deploy Tests ───
{"id":"deploy_odk_basic","description":"Deploy generated ODK","method":"POST","path":"/api/starodk/{{odkBasic.id}}/deploy","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":200}
{"id":"deploy_odk_advanced","description":"Deploy advanced ODK","method":"POST","path":"/api/starodk/{{odkAdvanced.id}}/deploy","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":200}

# ─── Update via CreateOrUpdate (upsert) ───
{"id":"update_odk_via_upsert","description":"Update existing ODK via CreateOrUpdate","method":"POST","path":"/api/starodk","headers":{"Content-Type":"application/json","Authorization":"Bearer {{starAuth.token}}"},"body":{"name":"BasicODK","description":"Updated description via upsert","publicKey":"0xUPDATEDPUBKEY999","avatarId":"{{starAvatar.id}}"},"expectedStatus":200}

# ─── Auth Tests ───
{"id":"get_odk_unauthorized","description":"Get ODK without auth","method":"GET","path":"/api/starodk/{{odkBasic.id}}","headers":{},"expectedStatus":401}
{"id":"create_odk_unauthorized","description":"Create ODK without auth","method":"POST","path":"/api/starodk","headers":{"Content-Type":"application/json"},"body":{"name":"UnauthODK","description":"Should fail"},"expectedStatus":401}
{"id":"delete_odk_unauthorized","description":"Delete ODK without auth","method":"DELETE","path":"/api/starodk/{{odkBasic.id}}","headers":{},"expectedStatus":401}
{"id":"generate_odk_unauthorized","description":"Generate without auth","method":"POST","path":"/api/starodk/{{odkBasic.id}}/generate","headers":{"Content-Type":"application/json"},"body":{"targetChain":"Algorand"},"expectedStatus":401}

# ─── Deploy before generate should fail ───
{"id":"create_fresh_odk","description":"Create fresh ODK for deploy-before-generate test","method":"POST","path":"/api/starodk","headers":{"Content-Type":"application/json","Authorization":"Bearer {{starAuth.token}}"},"body":{"name":"FreshODK","description":"No generation yet","publicKey":"0xFRESH","avatarId":"{{starAvatar.id}}"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"odkFresh"}
{"id":"deploy_before_generate","description":"Deploy ODK that was never generated should fail","method":"POST","path":"/api/starodk/{{odkFresh.id}}/deploy","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":400}

# ─── Cleanup ───
{"id":"delete_odk_basic","description":"Delete basic ODK","method":"DELETE","path":"/api/starodk/{{odkBasic.id}}","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":200}
{"id":"delete_odk_advanced","description":"Delete advanced ODK","method":"DELETE","path":"/api/starodk/{{odkAdvanced.id}}","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":200}
{"id":"delete_odk_unicode","description":"Delete unicode ODK","method":"DELETE","path":"/api/starodk/{{odkUnicode.id}}","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":200}
{"id":"delete_odk_fresh","description":"Delete fresh ODK","method":"DELETE","path":"/api/starodk/{{odkFresh.id}}","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":200}
{"id":"verify_deleted_odk","description":"Verify deleted ODK returns 404","method":"GET","path":"/api/starodk/{{odkBasic.id}}","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":404}
{"id":"cleanup_avatar","description":"Delete test avatar","method":"DELETE","path":"/api/avatar/{{starAvatar.id}}","headers":{"Authorization":"Bearer {{starAuth.token}}"},"expectedStatus":200}
