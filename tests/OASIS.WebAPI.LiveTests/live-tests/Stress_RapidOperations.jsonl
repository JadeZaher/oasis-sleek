# ─── Seed Stress Avatar ───
{"id":"stress_seed_avatar","description":"Register avatar for stress tests","method":"POST","path":"/api/avatar/register","headers":{"Content-Type":"application/json"},"body":{"username":"stresstest","email":"stress@load.oasis","password":"StressPass123!"},"expectedStatus":200,"extract":{"id":"result.id"},"saveAs":"stressAvatar"}
{"id":"stress_login","description":"Login stress avatar","method":"POST","path":"/api/avatar/login","headers":{"Content-Type":"application/json"},"body":{"email":"stress@load.oasis","password":"StressPass123!"},"expectedStatus":200,"extract":{"token":"result"},"saveAs":"stressAuth"}

