# ─── Rapid Interact Operations ───
{"id":"stress_interact_1","description":"Stress: rapid interact add peers","method":"POST","path":"/api/holon/{{stressHolon1.id}}/interact","headers":{"Content-Type":"application/json","Authorization":"Bearer {{stressAuth.token}}"},"body":{"addPeerHolonIds":["{{stressHolon2.id}}"],"setMetadata":{"peer":"2"}},"expectedStatus":200}
